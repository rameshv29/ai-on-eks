diff --git a/blueprints/citymapper-mcp/src/mcp_servers/visualization/Dockerfile b/blueprints/citymapper-mcp/src/mcp_servers/visualization/Dockerfile
new file mode 100644
index 0000000..51eb5d2
--- /dev/null
+++ b/blueprints/citymapper-mcp/src/mcp_servers/visualization/Dockerfile
@@ -0,0 +1,38 @@
+# Use Python 3.10 as the base image
+FROM python:3.10-slim
+
+# Set working directory
+WORKDIR /app
+
+# Set environment variables
+ENV PYTHONDONTWRITEBYTECODE=1 \
+    PYTHONUNBUFFERED=1 \
+    MCP_MAX_CONCURRENT_REQUESTS=100 \
+    MCP_REQUEST_TIMEOUT_SECONDS=300
+
+# Install system dependencies
+RUN apt-get update && apt-get install -y --no-install-recommends \
+    gcc \
+    default-libmysqlclient-dev \
+    curl \
+    && apt-get clean \
+    && rm -rf /var/lib/apt/lists/*
+
+# Copy requirements file
+COPY requirements.txt .
+
+# Install Python dependencies
+RUN pip install --no-cache-dir -r requirements.txt
+
+# Copy the server code and data
+COPY src/mcp_servers/visualization/ /app/src/mcp_servers/visualization/
+
+# Expose port
+EXPOSE 8006
+
+# Health check
+HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
+    CMD curl -f http://localhost:8006/health || exit 1
+
+# Command to run the server
+CMD ["python", "src/mcp_servers/visualization/server.py"]
